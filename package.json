{
  "name": "ame-pro-workstation",
  "version": "1.0.0",
  "description": "AME Pro AI Workstation — Desktop App for SA Professionals",
  "main": "./out/main/index.js",
  "author": "AME Pro",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "start": "electron-vite preview",
    "package": "electron-vite build && electron-builder",
    "package:win": "electron-vite build && electron-builder --win",
    "package:mac": "electron-vite build && electron-builder --mac",
    "package:linux": "electron-vite build && electron-builder --linux"
  },
  "dependencies": {
    "better-sqlite3": "^11.0.0",
    "clsx": "^2.1.0",
    "date-fns": "^3.0.0",
    "docx": "^8.5.0",
    "electron-updater": "^6.1.0",
    "exceljs": "^4.4.0",
    "highlight.js": "^11.11.1",
    "lucide-react": "^0.263.1",
    "mammoth": "^1.11.0",
    "pdf-lib": "^1.17.1",
    "pdf-parse": "^2.4.5",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^6.20.0",
    "recharts": "^2.10.0",
    "rehype-highlight": "^7.0.2",
    "remark-gfm": "^4.0.1",
    "tailwind-merge": "^2.2.0",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.2.0",
    "autoprefixer": "^10.4.16",
    "electron": "^33.0.0",
    "electron-builder": "^24.9.0",
    "electron-vite": "^2.3.0",
    "postcss": "^8.4.32",
    "tailwindcss": "^3.3.6",
    "vite": "^5.0.0"
  },
  "build": {
    "appId": "com.ame.pro-workstation",
    "productName": "AME Pro AI Workstation",
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "out/**/*"
    ],
    "extraResources": [
      {
        "from": "prompts",
        "to": "prompts"
      }
    ],
    "win": {
      "target": "nsis",
      "signAndEditExecutable": false
    },
    "mac": {
      "target": "dmg"
    },
    "linux": {
      "target": "AppImage"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "publish": null
  }
}
